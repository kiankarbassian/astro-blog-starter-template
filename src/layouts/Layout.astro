---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <!-- Custom cursor -->
    <div class="cursor" id="cursor"></div>
    <div class="cursor-follower" id="cursor-follower"></div>

    <!-- VHS tracking line -->
    <div class="vhs-line"></div>

    <slot />

    <script>
      // ── Scroll reveal ───────────────────────────────────────
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) entry.target.classList.add('visible');
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.animate-on-scroll').forEach(el => revealObserver.observe(el));

      // ── Custom cursor ───────────────────────────────────────
      const cursor = document.getElementById('cursor');
      const follower = document.getElementById('cursor-follower');
      let mouseX = 0, mouseY = 0, followerX = 0, followerY = 0;

      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        if (cursor) { cursor.style.left = mouseX + 'px'; cursor.style.top = mouseY + 'px'; }
      });

      function animateFollower() {
        followerX += (mouseX - followerX) * 0.12;
        followerY += (mouseY - followerY) * 0.12;
        if (follower) { follower.style.left = followerX + 'px'; follower.style.top = followerY + 'px'; }
        requestAnimationFrame(animateFollower);
      }
      animateFollower();

      document.querySelectorAll('a, button, [role="button"], .cassette-card, .transport-btn').forEach(el => {
        el.addEventListener('mouseenter', () => { cursor?.classList.add('cursor--hover'); follower?.classList.add('follower--hover'); });
        el.addEventListener('mouseleave', () => { cursor?.classList.remove('cursor--hover'); follower?.classList.remove('follower--hover'); });
      });

      // ── Magnetic hover ──────────────────────────────────────
      document.querySelectorAll('.magnetic').forEach(el => {
        el.addEventListener('mousemove', (e) => {
          const rect = (el as HTMLElement).getBoundingClientRect();
          const dx = (e as MouseEvent).clientX - (rect.left + rect.width / 2);
          const dy = (e as MouseEvent).clientY - (rect.top + rect.height / 2);
          (el as HTMLElement).style.transform = `translate(${dx * 0.22}px, ${dy * 0.22}px)`;
        });
        el.addEventListener('mouseleave', () => {
          (el as HTMLElement).style.transform = '';
          (el as HTMLElement).style.transition = 'transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1)';
          setTimeout(() => { (el as HTMLElement).style.transition = ''; }, 500);
        });
      });

      // ── Walkman 3D tilt on mousemove ───────────────────────
      const walkman = document.getElementById('walkman');
      const heroEl = document.querySelector('.hero') as HTMLElement;

      if (walkman && heroEl) {
        heroEl.addEventListener('mousemove', (e) => {
          const rect = heroEl.getBoundingClientRect();
          const cx = rect.left + rect.width / 2;
          const cy = rect.top + rect.height / 2;
          const dx = ((e as MouseEvent).clientX - cx) / (rect.width / 2);
          const dy = ((e as MouseEvent).clientY - cy) / (rect.height / 2);
          const rotY = dx * 12;
          const rotX = -dy * 8;
          (walkman as HTMLElement).style.transform = `perspective(900px) rotateY(${rotY}deg) rotateX(${rotX}deg) translateZ(10px)`;
        });
        heroEl.addEventListener('mouseleave', () => {
          (walkman as HTMLElement).style.transform = 'perspective(900px) rotateY(0deg) rotateX(0deg) translateZ(0px)';
        });
      }

      // ── Parallax ambient glows follow mouse ─────────────────
      document.addEventListener('mousemove', (e) => {
        const pct = { x: e.clientX / window.innerWidth, y: e.clientY / window.innerHeight };
        const glows = document.querySelectorAll('.glow');
        glows.forEach((g, i) => {
          const depth = 0.02 + i * 0.015;
          const offsetX = (pct.x - 0.5) * 120 * depth * (i % 2 === 0 ? 1 : -1);
          const offsetY = (pct.y - 0.5) * 80 * depth * (i % 2 === 0 ? 1 : -1);
          (g as HTMLElement).style.transform = `translate(${offsetX}px, ${offsetY}px)`;
        });
      });

      // ── Real scroll progress on LCD ─────────────────────────
      const lcdFill = document.querySelector('.lcd-progress-fill') as HTMLElement;
      const lcdTime = document.querySelector('.lcd-time') as HTMLElement;

      function updateLCDProgress() {
        const scrollable = document.documentElement.scrollHeight - window.innerHeight;
        const pct = scrollable > 0 ? Math.round((window.scrollY / scrollable) * 100) : 0;
        if (lcdFill) lcdFill.style.width = pct + '%';
        if (lcdTime) {
          const mins = Math.floor(pct * 0.45);
          const secs = Math.floor((pct * 0.45 % 1) * 60);
          lcdTime.textContent = String(mins).padStart(2, '0') + ':' + String(secs).padStart(2, '0');
        }
      }
      window.addEventListener('scroll', updateLCDProgress, { passive: true });

      // ── Scroll-linked reel speed ────────────────────────────
      let lastScrollY = window.scrollY;
      window.addEventListener('scroll', () => {
        const vel = Math.abs(window.scrollY - lastScrollY);
        lastScrollY = window.scrollY;
        const dur = Math.max(0.3, 3 - vel * 0.08) + 's';
        document.querySelectorAll('.tape-reel, .mini-reel').forEach(r => {
          (r as HTMLElement).style.animationDuration = dur;
        });
        clearTimeout((window as any)._reelTimeout);
        (window as any)._reelTimeout = setTimeout(() => {
          document.querySelectorAll('.tape-reel, .mini-reel').forEach(r => {
            (r as HTMLElement).style.animationDuration = '3s';
          });
        }, 300);
      }, { passive: true });

      // ── Floating nav visibility ─────────────────────────────
      const heroSection = document.querySelector('.hero');
      const floatingNav = document.getElementById('floating-nav');
      if (heroSection && floatingNav) {
        new IntersectionObserver((entries) => {
          entries.forEach(e => {
            floatingNav.classList.toggle('nav--visible', !e.isIntersecting);
          });
        }, { threshold: 0.1 }).observe(heroSection);
      }
    </script>
  </body>
</html>

<style is:global>
  /* Custom cursor styles */
  .cursor {
    position: fixed;
    width: 8px;
    height: 8px;
    background: var(--neon-cyan);
    border-radius: 50%;
    pointer-events: none;
    z-index: 10001;
    transform: translate(-50%, -50%);
    transition: width 0.2s, height 0.2s, background 0.2s;
    box-shadow: 0 0 6px var(--neon-cyan);
  }

  .cursor--hover {
    width: 12px;
    height: 12px;
    background: var(--neon-magenta);
    box-shadow: 0 0 10px var(--neon-magenta);
  }

  .cursor-follower {
    position: fixed;
    width: 32px;
    height: 32px;
    border: 1.5px solid rgba(0, 245, 255, 0.5);
    border-radius: 50%;
    pointer-events: none;
    z-index: 10000;
    transform: translate(-50%, -50%);
    transition: width 0.3s var(--ease-spring), height 0.3s var(--ease-spring), border-color 0.3s;
  }

  .follower--hover {
    width: 50px;
    height: 50px;
    border-color: rgba(255, 46, 147, 0.6);
  }

  .vhs-line {
    position: fixed;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06), transparent);
    pointer-events: none;
    z-index: 9998;
    animation: vhsTracking 10s linear infinite;
  }

  @media (hover: none) {
    .cursor, .cursor-follower { display: none; }
    body, a, button, [role="button"] { cursor: auto; }
  }
</style>
