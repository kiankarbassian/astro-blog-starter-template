---
const presets = [
  { num: "01", name: "GitHub", href: "https://github.com/FCFifadagoat" },
  { num: "02", name: "LinkedIn", href: "https://www.linkedin.com/in/kiankarbassian" },
  { num: "03", name: "Email", href: "mailto:kian@kiankarbassian.com" },
  { num: "04", name: "Phone", href: "tel:2177669918" }
];
---

<footer class="footer">
  <!-- Chrome top edge -->
  <div class="footer-chrome-edge" aria-hidden="true"></div>

  <div class="container">

    <!-- Top row: brand + battery + presets -->
    <div class="footer-top">

      <!-- Brand -->
      <div class="footer-brand">
        <span class="brand-logo chrome-text">KIAN</span>
        <span class="brand-tagline">Building autonomous AI systems</span>
        <div class="battery-indicator" aria-hidden="true" aria-label="Battery indicator">
          <span class="battery-shell">
            <span class="battery-nub"></span>
            <span class="battery-cell"></span>
            <span class="battery-cell"></span>
            <span class="battery-cell battery-cell--full"></span>
          </span>
          <span class="battery-label">FULL</span>
        </div>
      </div>

      <!-- Track listing (nav) -->
      <nav class="track-listing" aria-label="Site navigation">
        <span class="track-listing-label">TRACK LISTING</span>
        <a href="#projects" class="track-item">
          <span class="track-num">01</span>
          <span class="track-title">Work</span>
          <span class="track-dur">—————</span>
        </a>
        <a href="#about" class="track-item">
          <span class="track-num">02</span>
          <span class="track-title">About</span>
          <span class="track-dur">—————</span>
        </a>
        <a href="#contact" class="track-item">
          <span class="track-num">03</span>
          <span class="track-title">Contact</span>
          <span class="track-dur">—————</span>
        </a>
      </nav>

      <!-- Radio presets (social) -->
      <div class="radio-presets" aria-label="Social links">
        <span class="presets-label">PRESETS</span>
        <div class="presets-grid">
          {presets.map(p => (
            <a href={p.href} class="preset-btn magnetic" aria-label={p.name}>
              <span class="preset-num">{p.num}</span>
              <span class="preset-name">{p.name}</span>
            </a>
          ))}
        </div>
      </div>

    </div>

    <!-- Bottom row -->
    <div class="footer-bottom">
      <span class="footer-copyright">© 2026 KIAN KARBASSIAN</span>
      <span class="footer-stamp">BUILT WITH INTENTION · SIDE A</span>
      <span class="footer-model">KK-001 · DIGITAL EDITION</span>
    </div>

  </div>
</footer>

<style>
  /* ── Footer shell ───────────────────────────── */
  .footer {
    background: linear-gradient(180deg, #181820 0%, #141418 100%);
    padding: 3rem 0 1.5rem;
    position: relative;
  }

  /* Chrome top edge */
  .footer-chrome-edge {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255,255,255,0.04) 10%,
      rgba(255,255,255,0.15) 30%,
      rgba(255,255,255,0.25) 50%,
      rgba(255,255,255,0.15) 70%,
      rgba(255,255,255,0.04) 90%,
      transparent 100%
    );
  }

  /* ── Top section ────────────────────────────── */
  .footer-top {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    margin-bottom: 1.5rem;
  }

  /* ── Brand ─────────────────────────────────── */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .brand-logo {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.2em;
  }

  .brand-tagline {
    font-family: var(--font-lcd);
    font-size: 0.85rem;
    color: var(--gray);
    letter-spacing: 0.05em;
  }

  /* Battery */
  .battery-indicator {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .battery-shell {
    display: flex;
    align-items: center;
    gap: 2px;
    padding: 2px;
    border: 1px solid #555;
    border-radius: 3px;
    position: relative;
    background: #1a1a1a;
  }

  .battery-nub {
    position: absolute;
    right: -5px;
    width: 4px;
    height: 8px;
    background: #555;
    border-radius: 0 2px 2px 0;
  }

  .battery-cell {
    width: 8px;
    height: 12px;
    border-radius: 1px;
    background: rgba(57,255,20,0.15);
    border: 1px solid rgba(57,255,20,0.2);
  }

  .battery-cell--full {
    background: var(--lcd-green);
    box-shadow: 0 0 4px var(--lcd-green);
  }

  .battery-label {
    font-family: var(--font-lcd);
    font-size: 0.65rem;
    color: var(--lcd-green);
    text-shadow: 0 0 4px var(--lcd-green);
    letter-spacing: 0.1em;
  }

  /* ── Track Listing ──────────────────────────── */
  .track-listing {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .track-listing-label {
    font-family: var(--font-pixel);
    font-size: 0.4rem;
    color: var(--gray);
    letter-spacing: 0.15em;
    margin-bottom: 0.25rem;
  }

  .track-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--gray);
    font-family: var(--font-lcd);
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    padding: 0.25rem 0;
    transition: color 0.2s;
  }

  .track-item:hover {
    color: var(--neon-cyan);
    text-shadow: 0 0 6px var(--neon-cyan);
  }

  .track-num {
    color: rgba(255,255,255,0.3);
    font-size: 0.75rem;
    min-width: 1.5rem;
  }

  .track-title { flex: 1; }

  .track-dur {
    font-size: 0.6rem;
    opacity: 0.3;
    letter-spacing: 0.05em;
  }

  /* ── Radio Presets ──────────────────────────── */
  .radio-presets {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .presets-label {
    font-family: var(--font-pixel);
    font-size: 0.4rem;
    color: var(--gray);
    letter-spacing: 0.15em;
  }

  .presets-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .preset-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.5rem 0.5rem 0.4rem;
    background: linear-gradient(180deg, #3a3a3a 0%, #222 100%);
    border: 1px solid #444;
    border-radius: 4px;
    text-decoration: none;
    box-shadow:
      0 3px 0 #111,
      inset 0 1px 0 rgba(255,255,255,0.08);
    transition: all 0.1s;
  }

  .preset-btn:hover {
    border-color: var(--neon-cyan);
    box-shadow:
      0 3px 0 #111,
      0 0 8px rgba(0,245,255,0.2),
      inset 0 1px 0 rgba(255,255,255,0.08);
  }

  .preset-btn:hover .preset-num {
    color: var(--neon-cyan);
    text-shadow: 0 0 6px var(--neon-cyan);
  }

  .preset-btn:active {
    transform: translateY(3px);
    box-shadow: 0 0 0 #111, inset 0 1px 0 rgba(255,255,255,0.08);
  }

  .preset-num {
    font-family: var(--font-lcd);
    font-size: 0.9rem;
    color: var(--gray);
    transition: color 0.2s;
  }

  .preset-name {
    font-family: var(--font-pixel);
    font-size: 0.35rem;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.08em;
    margin-top: 0.15rem;
  }

  /* ── Footer bottom ──────────────────────────── */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: var(--font-lcd);
    font-size: 0.75rem;
    color: rgba(255,255,255,0.2);
    letter-spacing: 0.08em;
  }

  .footer-stamp {
    color: rgba(255,255,255,0.15);
  }

  /* ── Responsive ─────────────────────────────── */
  @media (max-width: 900px) {
    .footer-top { grid-template-columns: 1fr 1fr; }
    .radio-presets { display: none; }
  }

  @media (max-width: 600px) {
    .footer-top { grid-template-columns: 1fr; gap: 2rem; }
    .footer-bottom { justify-content: center; text-align: center; }
    .footer-stamp, .footer-model { display: none; }
  }
</style>
