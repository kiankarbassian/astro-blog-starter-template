---
const cassettes = [
  { id: 'projects', label: 'Work',    track: '01', color: '#00F5FF', side: 'A' },
  { id: 'about',    label: 'About',   track: '02', color: '#FF2E93', side: 'A' },
  { id: 'contact',  label: 'Contact', track: '03', color: '#E8A917', side: 'A' },
];
---

<nav class="cassette-rack" id="floating-nav" role="navigation" aria-label="Site navigation">
  <!-- Now playing pill -->
  <div class="rack-status">
    <span class="rack-dot"></span>
    <span class="rack-track" id="nav-track">INTRO</span>
  </div>

  <!-- Cassette slots -->
  <div class="rack-slots">
    {cassettes.map(c => (
      <a
        href={`#${c.id}`}
        class="rack-cassette magnetic"
        data-section={c.id}
        style={`--c: ${c.color}`}
        aria-label={c.label}
      >
        <!-- cassette body -->
        <div class="rc-body">
          <div class="rc-stripe"></div>
          <div class="rc-label">
            <span class="rc-side">SIDE {c.side} — {c.track}</span>
            <span class="rc-title">{c.label}</span>
          </div>
          <div class="rc-reels">
            <div class="rc-reel"></div>
            <div class="rc-reel"></div>
          </div>
        </div>
        <!-- active glow indicator -->
        <span class="rc-indicator"></span>
      </a>
    ))}
  </div>

  <!-- Hire button -->
  <a href="mailto:hello@example.com" class="rack-hire magnetic">
    <span class="hire-rec"></span>
    HIRE ME
  </a>
</nav>

<script>
  const sections = ['hero', 'projects', 'about', 'contact'];
  const navTrack = document.getElementById('nav-track');
  const labels: Record<string, string> = {
    hero:     'INTRO',
    projects: 'TRACK 01',
    about:    'TRACK 02',
    contact:  'TRACK 03',
  };

  new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const id = entry.target.id;
      document.querySelectorAll('.rack-cassette').forEach(c => c.classList.remove('rc--active'));
      document.querySelector(`.rack-cassette[data-section="${id}"]`)?.classList.add('rc--active');
      if (navTrack && labels[id]) navTrack.textContent = labels[id];
    });
  }, { threshold: 0.4 }).observe
  ;

  sections.forEach(id => {
    const el = document.getElementById(id);
    if (el) {
      new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          document.querySelectorAll('.rack-cassette').forEach(c => c.classList.remove('rc--active'));
          document.querySelector(`.rack-cassette[data-section="${id}"]`)?.classList.add('rc--active');
          if (navTrack && labels[id]) navTrack.textContent = labels[id];
        });
      }, { threshold: 0.4 }).observe(el);
    }
  });
</script>

<style>
  /* ── Rack container ─────────────────────────── */
  .cassette-rack {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(130%);
    z-index: 1000;
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    pointer-events: none;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.875rem;
    background: rgba(22, 22, 28, 0.9);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px;
    box-shadow:
      0 12px 40px rgba(0,0,0,0.6),
      inset 0 1px 0 rgba(255,255,255,0.06);
  }

  .cassette-rack.nav--visible {
    transform: translateX(-50%) translateY(0);
    pointer-events: all;
  }

  /* ── Status pill ────────────────────────────── */
  .rack-status {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding-right: 0.75rem;
    border-right: 1px solid rgba(255,255,255,0.08);
  }

  .rack-dot {
    width: 6px;
    height: 6px;
    background: var(--neon-cyan);
    border-radius: 50%;
    box-shadow: 0 0 5px var(--neon-cyan);
    animation: recBlink 1.8s ease-in-out infinite;
    flex-shrink: 0;
  }

  .rack-track {
    font-family: var(--font-lcd);
    font-size: 0.8rem;
    color: var(--lcd-green);
    text-shadow: 0 0 6px var(--lcd-green);
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  /* ── Cassette slots ─────────────────────────── */
  .rack-slots {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  /* ── Individual cassette ────────────────────── */
  .rack-cassette {
    position: relative;
    text-decoration: none;
    display: block;
  }

  .rc-body {
    width: 72px;
    height: 48px;
    background: linear-gradient(160deg, #3a3530 0%, #2a2520 100%);
    border-radius: 5px;
    border: 1.5px solid #4a4540;
    border-bottom-color: #1a1510;
    box-shadow:
      0 3px 0 #111,
      inset 0 1px 0 rgba(255,255,255,0.08);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.2s ease;
    position: relative;
  }

  .rc-stripe {
    height: 5px;
    background: var(--c);
    box-shadow: 0 0 6px var(--c);
    flex-shrink: 0;
  }

  .rc-label {
    padding: 0.2rem 0.3rem 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }

  .rc-side {
    font-family: var(--font-lcd);
    font-size: 0.48rem;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.05em;
    line-height: 1.2;
  }

  .rc-title {
    font-family: var(--font-heading);
    font-size: 0.62rem;
    font-weight: 700;
    color: var(--gray-light);
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .rc-reels {
    display: flex;
    justify-content: space-evenly;
    padding: 0.15rem 0.4rem 0.25rem;
  }

  .rc-reel {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: radial-gradient(circle at 50%, #111 0%, #222 60%, #111 100%);
    border: 1px solid #444;
  }

  /* Active dot below cassette */
  .rc-indicator {
    display: block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--c);
    box-shadow: 0 0 5px var(--c);
    margin: 0.25rem auto 0;
    opacity: 0;
    transition: opacity 0.25s;
  }

  /* Hover */
  .rack-cassette:hover .rc-body {
    transform: translateY(-3px);
    box-shadow: 0 6px 0 #111, 0 0 14px rgba(255,255,255,0.06), inset 0 1px 0 rgba(255,255,255,0.1);
    border-color: var(--c);
  }

  .rack-cassette:active .rc-body {
    transform: translateY(3px);
    box-shadow: 0 0 0 #111, inset 0 1px 0 rgba(255,255,255,0.08);
  }

  /* Active state */
  .rack-cassette.rc--active .rc-body {
    border-color: var(--c);
    box-shadow:
      0 3px 0 #111,
      0 0 12px color-mix(in srgb, var(--c) 40%, transparent),
      inset 0 1px 0 rgba(255,255,255,0.1);
  }

  .rack-cassette.rc--active .rc-title {
    color: var(--c);
    text-shadow: 0 0 6px var(--c);
  }

  .rack-cassette.rc--active .rc-indicator {
    opacity: 1;
    animation: recBlink 1.2s ease-in-out infinite;
  }

  /* Reel spin only when active */
  .rack-cassette.rc--active .rc-reel {
    animation: spinReel 2s linear infinite;
  }

  /* ── Hire button ────────────────────────────── */
  .rack-hire {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.875rem;
    background: linear-gradient(180deg, var(--neon-cyan) 0%, #00b8c0 100%);
    border-radius: 6px;
    color: #000;
    font-family: var(--font-lcd);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-decoration: none;
    box-shadow: 0 3px 0 #006670, 0 4px 12px rgba(0,245,255,0.25);
    transition: all 0.1s;
    margin-left: 0.25rem;
  }

  .rack-hire:active {
    transform: translateY(3px);
    box-shadow: 0 0 0 #006670;
  }

  .hire-rec {
    width: 6px;
    height: 6px;
    background: #000;
    border-radius: 50%;
    animation: recBlink 1.5s ease-in-out infinite;
  }

  @media (max-width: 520px) {
    .rack-status { display: none; }
    .rc-side { display: none; }
    .cassette-rack { gap: 0.5rem; padding: 0.5rem 0.75rem; }
  }
</style>
