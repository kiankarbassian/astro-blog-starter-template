---
const projects = [
  {
    title: "Neon Dashboard",
    description: "A futuristic analytics dashboard with real-time data visualization and dark mode aesthetics.",
    tags: ["React", "D3.js", "TypeScript"],
    color: "#FF2E93"
  },
  {
    title: "Ethereal Commerce",
    description: "High-end fashion e-commerce platform with smooth transitions and micro-interactions.",
    tags: ["Next.js", "Framer Motion", "Stripe"],
    color: "#FFE066"
  },
  {
    title: "Quantum Chat",
    description: "Real-time messaging app with end-to-end encryption and instant notifications.",
    tags: ["Node.js", "Socket.io", "Redis"],
    color: "#2D1B69"
  },
  {
    title: "Aurora Portfolio",
    description: "Creative agency portfolio with WebGL effects and immersive scroll experiences.",
    tags: ["Three.js", "GSAP", "Astro"],
    color: "#00D9FF"
  }
];
---

<section id="projects" class="projects section">
  <div class="container">
    <div class="section-header animate-on-scroll">
      <p class="section-subtitle">Featured Work</p>
      <h2 class="section-title">Projects</h2>
    </div>
    <div class="projects-grid">
      {projects.map((project, index) => (
        <article class="project-card animate-on-scroll" style={`--accent: ${project.color}; --delay: ${index * 0.1}s`}>
          <div class="project-visual">
            <div class="project-glow"></div>
            <div class="project-icon">{project.title[0]}</div>
          </div>
          <div class="project-content">
            <h3>{project.title}</h3>
            <p>{project.description}</p>
            <div class="project-tags">
              {project.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
          <div class="project-arrow">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M7 17L17 7M17 7H7M17 7V17"/>
            </svg>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects {
    background: linear-gradient(180deg, var(--dark) 0%, var(--dark-card) 100%);
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .project-card {
    position: relative;
    background: var(--dark-card);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    padding: 2rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.5rem;
    align-items: center;
    cursor: pointer;
    transition: all 0.4s var(--ease-out-expo);
    overflow: hidden;
  }

  .project-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--accent), transparent);
    opacity: 0;
    transition: opacity 0.4s var(--ease-out-expo);
  }

  .project-card:hover {
    transform: translateY(-8px);
    border-color: var(--accent);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
  }

  .project-card:hover::before {
    opacity: 0.1;
  }

  .project-card:hover .project-visual {
    transform: scale(1.1);
  }

  .project-card:hover .project-arrow {
    transform: translate(4px, -4px);
    color: var(--accent);
  }

  .project-visual {
    position: relative;
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, var(--accent), var(--purple-light));
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.4s var(--ease-out-expo);
  }

  .project-glow {
    position: absolute;
    inset: -20px;
    background: var(--accent);
    filter: blur(30px);
    opacity: 0.3;
  }

  .project-icon {
    font-size: 2rem;
    font-weight: 700;
    color: var(--white);
    z-index: 1;
  }

  .project-content h3 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--white);
  }

  .project-content p {
    color: var(--gray);
    font-size: 0.95rem;
    margin-bottom: 1rem;
    max-width: 400px;
  }

  .project-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    padding: 0.25rem 0.75rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    font-size: 0.75rem;
    color: var(--gray);
    font-weight: 500;
  }

  .project-arrow {
    color: var(--gray);
    transition: all 0.3s var(--ease-out-expo);
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }

    .project-card {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .project-visual {
      margin: 0 auto;
    }

    .project-tags {
      justify-content: center;
    }

    .project-arrow {
      display: none;
    }
  }
</style>
