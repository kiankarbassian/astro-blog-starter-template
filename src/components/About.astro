---
const skills = [
  { name: "Design", bars: 8, peak: 7 },
  { name: "Frontend", bars: 8, peak: 7 },
  { name: "Animation", bars: 8, peak: 8 },
  { name: "UI/UX", bars: 8, peak: 7 },
  { name: "Three.js", bars: 8, peak: 5 },
  { name: "Astro", bars: 8, peak: 6 },
];
---

<section id="about" class="about section">
  <div class="container">

    <div class="about-header animate-on-scroll">
      <span class="section-eyebrow">About Me</span>
      <h2 class="section-title">Liner Notes</h2>
    </div>

    <div class="about-grid">

      <!-- LEFT: J-Card / Liner Notes -->
      <div class="liner-notes animate-on-scroll from-left">
        <div class="jcard">
          <div class="jcard-header">
            <span class="jcard-label">LINER NOTES</span>
            <span class="jcard-catalog">CAT. NO. WM-001</span>
          </div>
          <div class="jcard-divider"></div>
          <div class="jcard-body">
            <p class="jcard-text">
              I'm a creative designer &amp; developer with a passion for building
              bold, immersive digital experiences. I believe great design should
              feel effortless — with smooth animations that delight at every turn.
            </p>
            <p class="jcard-text">
              With 5+ years crafting for startups and global brands, I blend
              aesthetic precision with technical depth. From pixel-perfect UI to
              WebGL experiments, I make the web feel alive.
            </p>
          </div>
          <div class="jcard-divider"></div>
          <div class="jcard-credits">
            <div class="credit-row">
              <span class="credit-key">Produced by</span>
              <span class="credit-val">Creative Studio</span>
            </div>
            <div class="credit-row">
              <span class="credit-key">Recorded in</span>
              <span class="credit-val">The Browser</span>
            </div>
            <div class="credit-row">
              <span class="credit-key">All rights</span>
              <span class="credit-val">Reserved © 2026</span>
            </div>
          </div>
          <div class="jcard-fold" aria-hidden="true"></div>
        </div>
      </div>

      <!-- RIGHT: Equalizer -->
      <div class="eq-panel animate-on-scroll from-right">
        <div class="eq-header">
          <span class="eq-label lcd-display">SKILL FREQ. ANALYZER</span>
          <span class="eq-mode">AUTO • STEREO</span>
        </div>
        <div class="eq-display">
          {skills.map((skill, si) => (
            <div class="eq-column">
              <div class="eq-bars">
                {Array.from({ length: skill.bars }).map((_, bi) => {
                  const isActive = bi < skill.peak;
                  const delay = (si * 0.15 + bi * 0.05).toFixed(2);
                  const dur = (1.8 + (si * 0.3 + bi * 0.1) % 1.2).toFixed(2);
                  return (
                    <div
                      class={`eq-bar${isActive ? ' eq-bar--active' : ''}`}
                      style={`animation-delay: ${delay}s; animation-duration: ${dur}s; --bar-index: ${bi}; --peak: ${skill.peak}`}
                    ></div>
                  );
                })}
              </div>
              <span class="eq-skill-name">{skill.name}</span>
            </div>
          ))}
        </div>
        <div class="eq-footer">
          <span class="eq-indicator">
            <span class="eq-dot"></span>
            LIVE
          </span>
          <span class="eq-db">0 dB</span>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ── Section ────────────────────────────────── */
  .about {
    background: linear-gradient(180deg, #1e1c20 0%, #1A1A1E 100%);
  }

  .about-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 3rem;
    align-items: stretch;
  }

  /* ── J-Card / Liner Notes ───────────────────── */
  .liner-notes { display: flex; }

  .jcard {
    background: var(--cassette-cream);
    border-radius: 4px;
    padding: 2rem;
    position: relative;
    box-shadow:
      4px 4px 0 rgba(0,0,0,0.4),
      8px 8px 0 rgba(0,0,0,0.2),
      0 20px 40px rgba(0,0,0,0.3);
    width: 100%;
    /* Subtle paper texture via repeating gradient */
    background-image:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 22px,
        rgba(0,0,0,0.03) 22px,
        rgba(0,0,0,0.03) 23px
      ),
      linear-gradient(180deg, #F8E8C0 0%, #F2DDB0 100%);
  }

  /* Fold crease on right edge */
  .jcard-fold {
    position: absolute;
    right: 0; top: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, transparent, rgba(0,0,0,0.12) 30%, rgba(0,0,0,0.08) 70%, transparent);
  }

  .jcard-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.75rem;
  }

  .jcard-label {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--cassette-brown);
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .jcard-catalog {
    font-family: var(--font-lcd);
    font-size: 0.75rem;
    color: rgba(92,61,30,0.5);
    letter-spacing: 0.1em;
  }

  .jcard-divider {
    height: 2px;
    background: linear-gradient(90deg, var(--neon-magenta), var(--mustard));
    border-radius: 1px;
    margin: 0.75rem 0;
    box-shadow: 0 0 4px rgba(232,169,23,0.3);
  }

  .jcard-body { margin: 1rem 0; }

  .jcard-text {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--cassette-brown);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .jcard-credits { display: flex; flex-direction: column; gap: 0.35rem; }

  .credit-row {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-lcd);
    font-size: 0.8rem;
  }

  .credit-key { color: rgba(92,61,30,0.6); }
  .credit-val { color: var(--cassette-brown); font-weight: 500; }

  /* ── Equalizer Panel ────────────────────────── */
  .eq-panel {
    background: var(--dark-card);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    box-shadow: inset 0 2px 8px rgba(0,0,0,0.3);
  }

  .eq-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .eq-label {
    font-size: 0.8rem;
    padding: 0.3rem 0.6rem;
    font-family: var(--font-lcd);
  }

  .eq-mode {
    font-family: var(--font-lcd);
    font-size: 0.75rem;
    color: var(--gray);
    letter-spacing: 0.08em;
  }

  .eq-display {
    display: flex;
    gap: 0.75rem;
    align-items: flex-end;
    height: 160px;
    padding: 0.5rem;
    background: #0e0e12;
    border-radius: 6px;
    border: 1px solid rgba(255,255,255,0.04);
    box-shadow: inset 0 2px 6px rgba(0,0,0,0.5);
    flex: 1;
  }

  .eq-column {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    height: 100%;
  }

  .eq-bars {
    flex: 1;
    width: 100%;
    display: flex;
    flex-direction: column-reverse;
    gap: 2px;
    align-items: center;
    justify-content: flex-start;
  }

  .eq-bar {
    width: 100%;
    max-width: 22px;
    height: 10px;
    border-radius: 1px;
    background: rgba(255,255,255,0.04);
    transition: background 0.3s;
  }

  .eq-bar--active {
    background: var(--neon-cyan);
    box-shadow: 0 0 4px var(--neon-cyan);
    animation: eqPulse var(--dur, 2s) ease-in-out infinite;
  }

  /* Color shift as bars go higher */
  .eq-bar--active:nth-child(1),
  .eq-bar--active:nth-child(2) {
    background: var(--neon-cyan);
    box-shadow: 0 0 4px var(--neon-cyan);
  }

  .eq-bar--active:nth-child(3),
  .eq-bar--active:nth-child(4),
  .eq-bar--active:nth-child(5) {
    background: var(--mustard);
    box-shadow: 0 0 4px var(--mustard);
  }

  .eq-bar--active:nth-child(6),
  .eq-bar--active:nth-child(7),
  .eq-bar--active:nth-child(8) {
    background: var(--neon-magenta);
    box-shadow: 0 0 6px var(--neon-magenta);
  }

  .eq-skill-name {
    font-family: var(--font-lcd);
    font-size: 0.65rem;
    color: var(--gray);
    letter-spacing: 0.04em;
    white-space: nowrap;
    text-align: center;
  }

  .eq-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .eq-indicator {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-lcd);
    font-size: 0.75rem;
    color: var(--neon-magenta);
    text-shadow: 0 0 6px var(--neon-magenta);
  }

  .eq-dot {
    width: 6px; height: 6px;
    background: var(--neon-magenta);
    border-radius: 50%;
    box-shadow: 0 0 6px var(--neon-magenta);
    animation: recBlink 1.5s ease-in-out infinite;
  }

  .eq-db {
    font-family: var(--font-lcd);
    font-size: 0.75rem;
    color: var(--gray);
    letter-spacing: 0.05em;
  }

  /* ── Responsive ─────────────────────────────── */
  @media (max-width: 968px) {
    .about-grid { grid-template-columns: 1fr; }
    .eq-display { height: 120px; }
  }
</style>
